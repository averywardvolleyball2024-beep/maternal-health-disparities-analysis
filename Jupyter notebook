<div class="highlight hl-ipython3"><pre><span></span><span class="k">def</span><span class="w"> </span><span class="nf">classify_birth</span><span class="p">(</span><span class="n">gestational_age</span><span class="p">):</span>
    <span class="k">if</span> <span class="n">gestational_age</span> <span class="o">&lt;</span> <span class="mf">28.00</span><span class="p">:</span>
        <span class="k">return</span> <span class="s2">"Extremely Preterm"</span>
    <span class="k">elif</span> <span class="n">gestational_age</span> <span class="o">&lt;</span> <span class="mf">32.00</span><span class="p">:</span>
        <span class="k">return</span> <span class="s2">"Very PreTerm"</span>
    <span class="k">elif</span> <span class="n">gestational_age</span> <span class="o">&lt;</span> <span class="mf">37.00</span><span class="p">:</span>
        <span class="k">return</span><span class="s2">"Preterm"</span>
    <span class="k">else</span><span class="p">:</span>
        <span class="k">return</span> <span class="s2">"Full Term"</span>
    <span class="n">A</span><span class="p">[</span><span class="s2">"Birth_Category"</span><span class="p">]</span><span class="o">=</span> <span class="n">A</span><span class="p">[</span><span class="s2">"Average OE Gestational Age (weeks)"</span><span class="p">]</span><span class="o">.</span><span class="n">apply</span><span class="p">(</span><span class="n">classify_birth</span><span class="p">)</span>
